# EVE Chatbot — Ingestion script environment variables
# Copy this file to scripts/.env and fill in your values.
# NEVER commit scripts/.env to source control.
# The service role key has full database access — treat it like a password.

SUPABASE_URL=https://kaudxtbqjojehbemtdpt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key from Supabase dashboard>

# Voyage AI — embeddings (voyage-3, 1024 dims)
# Get your key at: https://dash.voyageai.com
VOYAGE_API_KEY=<voyage-api-key>

# Anthropic Claude — used in Phase 2 (edge function), not needed for ingestion
# ANTHROPIC_API_KEY=<anthropic-api-key>
